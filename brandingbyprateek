  <script>
    const cur = document.getElementById('cur'), ring = document.getElementById('ring');
    let mx = 0, my = 0, rx = 0, ry = 0;
    document.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY; cur.style.left = mx + 'px'; cur.style.top = my + 'px'; });
    (function a() { rx += (mx - rx) * .1; ry += (my - ry) * .1; ring.style.left = rx + 'px'; ring.style.top = ry + 'px'; requestAnimationFrame(a); })();
    document.querySelectorAll('a,button,.svc-card,.p-card,.cl-logo').forEach(el => {
      el.addEventListener('mouseenter', () => { cur.style.width = '18px'; cur.style.height = '18px'; ring.style.width = '55px'; ring.style.height = '55px'; ring.style.borderColor = 'rgba(186,218,84,.5)'; });
      el.addEventListener('mouseleave', () => { cur.style.width = '10px'; cur.style.height = '10px'; ring.style.width = '36px'; ring.style.height = '36px'; ring.style.borderColor = 'rgba(239,239,239,.35)'; });
    });
    window.addEventListener('scroll', () => {
      const n = document.getElementById('nav');
      if (window.scrollY > 80) { n.style.background = 'rgba(0,0,0,.94)'; n.style.backdropFilter = 'blur(14px)'; }
      else { n.style.background = 'transparent'; n.style.backdropFilter = 'none'; }
    });
    const obs = new IntersectionObserver(e => e.forEach(x => { if (x.isIntersecting) x.target.classList.add('vis'); }), { threshold: .07 });
    document.querySelectorAll('.rv,.rv-l,.rv-r').forEach(el => obs.observe(el));
    document.querySelectorAll('.p-tab').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.p-tab').forEach(b => b.classList.remove('on'));
        document.querySelectorAll('.port-panel').forEach(p => p.classList.remove('active'));
        btn.classList.add('on');
        const panel = document.getElementById('panel-' + btn.dataset.panel);
        if (panel) panel.classList.add('active');
      });
    });
    const reelCards = document.querySelectorAll('.reel-card');
    function createReelEmbed(card) {
      const src = card.dataset.url;
      const player = card.querySelector('.reel-player');
      if (!src || !player) return;
      
      const encodedSrc = src.replace(/#/g, '%23');
      
      const video = document.createElement('video');
      video.src = encodedSrc;
      video.muted = false;
      video.autoplay = false;
      video.playsInline = true;
      video.loop = true;
      video.controls = true;
      video.preload = 'metadata';
      video.style.width = '100%';
      video.style.height = '100%';
      video.style.objectFit = 'cover';
      video.style.cursor = 'pointer';
      
      player.innerHTML = '';
      player.appendChild(video);
      
      card.addEventListener('click', (e) => {
        // Prevent interfering if user clicked directly on native controls (usually bottom area)
        // But allowing it is mostly fine, play() on playing video is a no-op.
        if (video.paused) {
          // Pause other videos
          document.querySelectorAll('.reel-player video').forEach(v => {
            if(v !== video) v.pause();
          });
          video.play();
        } else {
          // Only pause if clicking outside the native controls area if possible, 
          // or just let native controls handle their own clicks.
          // e.target is the video or the card.
          if (e.target !== video) {
            video.pause();
          }
        }
      });
      
      video.addEventListener('play', () => {
        card.classList.add('reel-active');
      });
      
      video.addEventListener('pause', () => {
        card.classList.remove('reel-active');
      });
    }
    function initReels() {
      reelCards.forEach(createReelEmbed);
    }
    initReels();
    document.querySelectorAll('.svc-card').forEach(card => {
      card.style.perspective = '1000px';
      card.addEventListener('mousemove', e => {
        const r = card.getBoundingClientRect();
        const x = e.clientX - r.left - r.width / 2;
        const y = e.clientY - r.top - r.height / 2;
        const rx2 = (-y / r.height) * 10;
        const ry2 = (x / r.width) * 10;
        card.style.transform = `translateY(-8px) scale(1.01) rotateX(${rx2}deg) rotateY(${ry2}deg)`;
        card.style.transition = 'box-shadow .4s,border-color .4s';
        const g = card.querySelector('.svc-glow');
        if (g) { g.style.left = ((e.clientX - r.left) / r.width * 100) + '%'; g.style.top = ((e.clientY - r.top) / r.height * 100) + '%'; }
      });
      card.addEventListener('mouseleave', () => { card.style.transform = ''; card.style.transition = 'transform .4s cubic-bezier(.23,1,.32,1),box-shadow .4s,border-color .4s'; });
    });
    function animCount(el, target, suffix) { let c = 0; const step = target / 55; const iv = setInterval(() => { c += step; if (c >= target) { c = target; clearInterval(iv); } el.textContent = Math.floor(c) + suffix; }, 16); }
    const so = new IntersectionObserver(e => e.forEach(x => { if (x.isIntersecting) { x.target.querySelectorAll('.stn').forEach(n => { const t = n.textContent; const v = parseInt(t); const s = t.replace(String(v), ''); animCount(n, v, s); }); so.unobserve(x.target); } }), { threshold: .5 });
    document.querySelectorAll('.stats').forEach(el => so.observe(el));
  </script>
