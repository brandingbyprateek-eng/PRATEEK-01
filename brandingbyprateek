<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0" />
  <title>Branding by Prateek</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap"
    rel="stylesheet" />
  <style>
    @font-face {
      font-family: 'Handodle';
      src: url('data:font/truetype;base64,') format('truetype');
    }

    *,
    *::before,
    *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --black: #000;
      --white: #efefef;
      --accent: #bada54;
      --f: 'Poppins', sans-serif;
      --fh: 'Handodle', cursive;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      background: var(--black);
      color: var(--white);
      font-family: var(--f);
      cursor: none;
      overflow-x: hidden;
    }

    /* CURSOR */
    .cur {
      position: fixed;
      width: 10px;
      height: 10px;
      background: var(--accent);
      border-radius: 50%;
      pointer-events: none;
      z-index: 9999;
      transform: translate(-50%, -50%);
      mix-blend-mode: difference;
      transition: width .2s, height .2s;
    }

    .cur-r {
      position: fixed;
      width: 36px;
      height: 36px;
      border: 1px solid rgba(239, 239, 239, .35);
      border-radius: 50%;
      pointer-events: none;
      z-index: 9998;
      transform: translate(-50%, -50%);
      transition: width .15s, height .15s;
    }

    /* NAV */
    nav {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      z-index: 100;
      padding: 1.3rem 3rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      transition: background .4s;
    }

    .nav-logo {
      display: flex;
      align-items: center;
      gap: .6rem;
    }

    .nav-logo img {
      height: 90px;
      filter: brightness(0) invert(1);
      opacity: .9;
    }

    .nav-links {
      display: flex;
      gap: 2.5rem;
    }

    .nav-links a {
      font-size: .6rem;
      font-weight: 600;
      letter-spacing: .25em;
      text-transform: uppercase;
      color: rgba(239, 239, 239, .65);
      text-decoration: none;
      transition: color .3s;
      position: relative;
    }

    .nav-links a::after {
      content: '';
      position: absolute;
      bottom: -4px;
      left: 0;
      width: 0;
      height: 1px;
      background: var(--accent);
      transition: width .3s;
    }

    .nav-links a:hover {
      color: var(--white);
    }

    .nav-links a:hover::after {
      width: 100%;
    }

    /* HERO */
    .hero {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      padding: 7rem 3rem 5rem;
      position: relative;
      overflow: hidden;
    }

    .hero-bg {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      font-size: 32vw;
      font-weight: normal;
      color: transparent;
      -webkit-text-stroke: 1px rgba(239, 239, 239, .03);
      pointer-events: none;
      user-select: none;
      font-family: var(--fh);
      white-space: nowrap;
    }

    .hero-tag {
      font-size: .6rem;
      font-weight: 600;
      letter-spacing: .45em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 2rem;
      opacity: 0;
      animation: fu .7s .3s forwards;
    }

    .hero-h {
      font-family: var(--fh);
      font-size: clamp(3.5rem, 8.5vw, 10rem);
      font-weight: normal;
      line-height: 1.1;
      opacity: 0;
      animation: fu .9s .5s forwards;
    }

    .hero-h .l2 {
      color: var(--accent);
    }

    .hero-div {
      width: 60px;
      height: 1px;
      background: rgba(239, 239, 239, .18);
      margin: 2.5rem auto;
      opacity: 0;
      animation: fu .7s .8s forwards;
    }

    .hero-sub {
      font-size: .82rem;
      font-weight: 400;
      color: rgba(239, 239, 239, .5);
      letter-spacing: .08em;
      opacity: 0;
      animation: fu .7s .9s forwards;
    }

    .hero-cta {
      margin-top: 2.5rem;
      opacity: 0;
      animation: fu .8s 1.1s forwards;
    }

    .hero-steps {
      display: flex;
      margin-top: 4rem;
      width: 100%;
      opacity: 0;
      animation: fu .8s 1.2s forwards;
      border-top: 1px solid rgba(239, 239, 239, .08);
    }

    .hs {
      flex: 1;
      padding: 1.4rem;
      border-right: 1px solid rgba(239, 239, 239, .08);
      text-align: left;
    }

    .hs:last-child {
      border-right: none;
    }

    .hs-n {
      font-size: .5rem;
      font-weight: 700;
      letter-spacing: .3em;
      color: var(--accent);
      margin-bottom: .35rem;
    }

    .hs-l {
      font-size: .52rem;
      font-weight: 500;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: rgba(239, 239, 239, .35);
      margin-bottom: .3rem;
    }

    .hs-t {
      font-size: .78rem;
      font-weight: 600;
      color: rgba(239, 239, 239, .85);
    }

    .scroll-w {
      position: absolute;
      bottom: 2rem;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: .5rem;
      opacity: 0;
      animation: fu .8s 1.6s forwards;
    }

    .scroll-l {
      width: 1px;
      height: 50px;
      background: rgba(239, 239, 239, .1);
      position: relative;
      overflow: hidden;
    }

    .scroll-l::after {
      content: '';
      position: absolute;
      top: -100%;
      left: 0;
      width: 100%;
      height: 100%;
      background: var(--accent);
      animation: sp 2s ease-in-out infinite;
    }

    @keyframes sp {
      0% {
        top: -100%;
      }

      100% {
        top: 200%;
      }
    }

    .scroll-t {
      font-size: .48rem;
      font-weight: 600;
      letter-spacing: .3em;
      text-transform: uppercase;
      color: rgba(239, 239, 239, .28);
    }

    /* BTN */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: .8rem;
      padding: .95rem 2.2rem;
      border: 1px solid rgba(239, 239, 239, .4);
      font-family: var(--f);
      font-size: .6rem;
      font-weight: 600;
      letter-spacing: .25em;
      text-transform: uppercase;
      color: var(--white);
      text-decoration: none;
      cursor: none;
      position: relative;
      overflow: hidden;
      transition: color .4s, border-color .4s;
    }

    .btn::after {
      content: '';
      position: absolute;
      inset: 0;
      background: var(--accent);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform .45s cubic-bezier(.77, 0, .18, 1);
      z-index: -1;
    }

    .btn:hover {
      color: var(--black);
      border-color: var(--accent);
    }

    .btn:hover::after {
      transform: scaleX(1);
    }

    /* MARQUEE */
    .marquee {
      border-top: 1px solid rgba(239, 239, 239, .07);
      border-bottom: 1px solid rgba(239, 239, 239, .07);
      padding: .8rem 0;
      overflow: hidden;
    }

    .mq-track {
      display: flex;
      gap: 3rem;
      animation: mq 28s linear infinite;
      white-space: nowrap;
    }

    .mq-item {
      flex-shrink: 0;
      display: flex;
      align-items: center;
      gap: .8rem;
      font-size: .55rem;
      font-weight: 600;
      letter-spacing: .35em;
      text-transform: uppercase;
      color: rgba(239, 239, 239, .28);
    }

    .mq-dot {
      width: 4px;
      height: 4px;
      background: var(--accent);
      border-radius: 50%;
    }

    @keyframes mq {
      from {
        transform: translateX(0);
      }

      to {
        transform: translateX(-50%);
      }
    }

    /* ABOUT */
    .about {
      padding: 9rem 3rem;
      display: grid;
      grid-template-columns: 1fr 1.3fr;
      gap: 7rem;
      align-items: center;
      border-top: 1px solid rgba(239, 239, 239, .07);
    }

    .about-iw {
      position: relative;
    }

    .about-img {
      width: 100%;
      aspect-ratio: 3/4;
      object-fit: cover;
      object-position: top;
      filter: grayscale(15%);
      display: block;
    }

    .about-acc {
      position: absolute;
      bottom: -1.5rem;
      right: -1.5rem;
      width: 55%;
      aspect-ratio: 1;
      border: 1px solid rgba(186, 218, 84, .18);
      pointer-events: none;
    }

    .stag {
      font-size: .56rem;
      font-weight: 600;
      letter-spacing: .45em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 1.2rem;
    }

    .abar {
      width: 32px;
      height: 2px;
      background: var(--accent);
      margin-bottom: 2rem;
    }

    .ah {
      font-size: clamp(2rem, 3.2vw, 3.5rem);
      font-weight: 600;
      line-height: 1.1;
      letter-spacing: -.02em;
      margin-bottom: 2rem;
      color: var(--white);
    }

    .ah em {
      font-style: normal;
      color: var(--accent);
    }

    .abio {
      font-size: .92rem;
      font-weight: 300;
      line-height: 1.9;
      color: rgba(239, 239, 239, .65);
      margin-bottom: 1.2rem;
    }

    .aq {
      font-size: 1.15rem;
      font-weight: 600;
      line-height: 1.35;
      padding-left: 1.5rem;
      border-left: 2px solid var(--accent);
      margin: 2.5rem 0;
      color: rgba(239, 239, 239, .9);
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
      margin-top: 3rem;
      padding-top: 2.5rem;
      border-top: 1px solid rgba(239, 239, 239, .08);
    }

    .stn {
      font-size: 3rem;
      font-weight: 700;
      color: var(--accent);
      line-height: 1;
      letter-spacing: -.04em;
    }

    .stl {
      font-size: .52rem;
      font-weight: 500;
      letter-spacing: .2em;
      text-transform: uppercase;
      color: rgba(239, 239, 239, .5);
      margin-top: .4rem;
    }

    /* ═══ CLIENTS — BLACK + WHITE LOGOS + SLIDER ═══ */
    .clients {
      background: var(--black);
      padding: 5rem 0;
      overflow: hidden;
      border-top: 1px solid rgba(239, 239, 239, .07);
      border-bottom: 1px solid rgba(239, 239, 239, .07);
    }

    .cl-head {
      text-align: center;
      padding: 0 3rem 3rem;
    }

    .cl-title {
      font-size: .55rem;
      font-weight: 700;
      letter-spacing: .45em;
      text-transform: uppercase;
      color: rgba(239, 239, 239, .4);
    }

    .cl-slider {
      position: relative;
      overflow: hidden;
    }

    .cl-slider::before,
    .cl-slider::after {
      content: '';
      position: absolute;
      top: 0;
      width: 180px;
      height: 100%;
      z-index: 2;
      pointer-events: none;
    }

    .cl-slider::before {
      left: 0;
      background: linear-gradient(to right, #000 20%, transparent);
    }

    .cl-slider::after {
      right: 0;
      background: linear-gradient(to left, #000 20%, transparent);
    }

    .cl-track {
      display: flex;
      align-items: center;
      gap: 6rem;
      animation: clS 24s linear infinite;
      white-space: nowrap;
      padding: 1.5rem 0;
    }

    .cl-track:hover {
      animation-play-state: paused;
    }

    .cl-logo {
      flex-shrink: 0;
      height: 50px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .cl-logo img {
      height: 100%;
      max-width: 150px;
      object-fit: contain;
      filter: brightness(0) invert(1);
      opacity: .5;
      transition: opacity .4s, transform .4s;
    }

    .cl-logo:hover img {
      opacity: 1;
      transform: scale(1.08);
    }

    @keyframes clS {
      from {
        transform: translateX(0);
      }

      to {
        transform: translateX(-50%);
      }
    }

    /* ═══ SERVICES — 3D GLASS CARDS ═══ */
    .services {
      padding: 9rem 3rem;
      border-top: 1px solid rgba(239, 239, 239, .07);
    }

    .sec-head {
      text-align: center;
      margin-bottom: 5rem;
    }

    .sec-h {
      font-size: clamp(2.5rem, 5vw, 5.5rem);
      font-weight: 600;
      line-height: .95;
      letter-spacing: -.03em;
      color: var(--white);
    }

    .sec-h em {
      font-style: normal;
      color: var(--accent);
    }

    .sec-sub {
      font-size: .85rem;
      font-weight: 300;
      color: rgba(239, 239, 239, .5);
      margin-top: 1rem;
      letter-spacing: .03em;
    }

    .svc-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    .svc-card {
      position: relative;
      padding: 2.5rem 2rem 2rem;
      background: rgba(255, 255, 255, .028);
      border: 1px solid rgba(255, 255, 255, .09);
      border-radius: 18px;
      backdrop-filter: blur(10px);
      overflow: hidden;
      transition: transform .4s cubic-bezier(.23, 1, .32, 1), box-shadow .4s, border-color .4s;
      text-align: center;
      cursor: none;
      display: flex;
      flex-direction: column;
      align-items: center;
      transform-style: preserve-3d;
    }

    .svc-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(255, 255, 255, .055) 0%, transparent 60%, rgba(186, 218, 84, .03) 100%);
      pointer-events: none;
      border-radius: 18px;
    }

    .svc-card::after {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 60%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, .05), transparent);
      transition: left .7s ease;
      pointer-events: none;
    }

    .svc-card:hover::after {
      left: 150%;
    }

    .svc-card:hover {
      box-shadow: 0 32px 64px rgba(0, 0, 0, .5), 0 0 40px rgba(186, 218, 84, .07), inset 0 1px 0 rgba(255, 255, 255, .12);
      border-color: rgba(186, 218, 84, .28);
    }

    .svc-num {
      font-size: .52rem;
      font-weight: 700;
      letter-spacing: .3em;
      color: rgba(186, 218, 84, .6);
      margin-bottom: 1.2rem;
    }

    .svc-icon {
      font-size: 1.8rem;
      margin-bottom: 1.1rem;
      line-height: 1;
      color: rgba(239, 239, 239, .6);
    }

    .svc-title {
      font-size: 1rem;
      font-weight: 600;
      letter-spacing: -.01em;
      margin-bottom: 1rem;
      color: var(--white);
    }

    .svc-desc {
      font-size: .76rem;
      font-weight: 300;
      line-height: 1.75;
      color: rgba(239, 239, 239, .55);
      margin-bottom: 1.5rem;
      flex: 1;
    }

    .svc-tags {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: .35rem;
      margin-bottom: 1.8rem;
    }

    .svc-tag {
      font-size: .46rem;
      font-weight: 500;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: rgba(186, 218, 84, .55);
      padding: .2rem .65rem;
      border: 1px solid rgba(186, 218, 84, .15);
      border-radius: 100px;
    }

    .svc-btn {
      display: inline-flex;
      align-items: center;
      gap: .5rem;
      padding: .6rem 1.5rem;
      background: rgba(186, 218, 84, .08);
      border: 1px solid rgba(186, 218, 84, .22);
      border-radius: 100px;
      font-family: var(--f);
      font-size: .52rem;
      font-weight: 600;
      letter-spacing: .2em;
      text-transform: uppercase;
      color: var(--accent);
      text-decoration: none;
      cursor: none;
      transition: all .3s;
      margin-top: auto;
    }

    .svc-btn:hover {
      background: var(--accent);
      color: var(--black);
      border-color: var(--accent);
    }

    .svc-glow {
      position: absolute;
      width: 220px;
      height: 220px;
      border-radius: 50%;
      background: rgba(186, 218, 84, .05);
      pointer-events: none;
      transform: translate(-50%, -50%);
      filter: blur(50px);
      transition: top .2s, left .2s;
    }

    /* ═══ PORTFOLIO — TABBED MINIMAL ═══ */
    .portfolio {
      padding: 9rem 3rem;
      border-top: 1px solid rgba(239, 239, 239, .07);
    }

    .port-head {
      text-align: center;
      margin-bottom: 4rem;
    }

    .port-h {
      font-size: clamp(2.5rem, 5vw, 5.5rem);
      font-weight: 600;
      line-height: .95;
      letter-spacing: -.03em;
      color: var(--white);
    }

    .port-h em {
      font-style: normal;
      color: var(--accent);
    }

    .port-sub {
      font-size: .85rem;
      font-weight: 300;
      color: rgba(239, 239, 239, .5);
      margin-top: 1rem;
    }

    .port-tabs {
      display: flex;
      justify-content: center;
      gap: .5rem;
      margin-bottom: 3.5rem;
      flex-wrap: wrap;
    }

    .p-tab {
      font-family: var(--f);
      font-size: .55rem;
      font-weight: 600;
      letter-spacing: .18em;
      text-transform: uppercase;
      padding: .55rem 1.3rem;
      border: 1px solid rgba(239, 239, 239, .12);
      background: transparent;
      color: rgba(239, 239, 239, .5);
      cursor: none;
      transition: all .3s;
      border-radius: 100px;
      display: flex;
      align-items: center;
      gap: .5rem;
    }

    .p-tab .tc {
      font-size: .45rem;
      background: rgba(239, 239, 239, .08);
      padding: .1rem .45rem;
      border-radius: 100px;
    }

    .p-tab.on,
    .p-tab:hover {
      background: var(--accent);
      border-color: var(--accent);
      color: var(--black);
    }

    .p-tab.on .tc,
    .p-tab:hover .tc {
      background: rgba(0, 0, 0, .18);
    }

    .port-panel {
      display: none;
    }

    .port-panel.active {
      display: block;
      animation: pf .4s ease;
    }

    @keyframes pf {
      from {
        opacity: 0;
        transform: translateY(8px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* Grid layouts */
    .g5 {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 3px;
    }

    /* logos */
    .g4p {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 3px;
    }

    /* reels/book/thumb */
    .g8 {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 3px;
    }

    /* social/print 4 col × 2 row */

    /* Placeholder cards */
    .p-card {
      background: #080808;
      position: relative;
      overflow: hidden;
      cursor: none;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: .55rem;
      transition: background .3s;
      text-decoration: none;
    }

    .p-card.sq {
      aspect-ratio: 1/1;
    }

    .p-card.pt {
      aspect-ratio: 9/16;
      position: relative;
      overflow: hidden;
      background: #111 center/cover no-repeat;
      background-size: cover;
      background-position: center;
      color: var(--white);
      cursor: pointer;
    }

    .p-card.ls {
      aspect-ratio: 4/3;
    }

    .p-card.bk {
      aspect-ratio: 3/4;
    }

    .p-card.th {
      aspect-ratio: 16/9;
    }

    .p-card.pt::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, rgba(0, 0, 0, .18), rgba(0, 0, 0, .65));
      pointer-events: none;
      z-index: 0;
    }

    .reel-card .p-card-icon {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 64px;
      height: 64px;
      border-radius: 50%;
      background: rgba(186, 218, 84, .14);
      border: 2px solid rgba(186, 218, 84, .65);
      color: var(--accent);
      font-size: 1.8rem;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 2;
      transition: transform .3s, background .3s;
    }

    .reel-card:hover .p-card-icon {
      transform: translate(-50%, -50%) scale(1.05);
      background: rgba(186, 218, 84, .24);
    }

    .reel-card .p-card-lbl {
      position: absolute;
      left: 1rem;
      bottom: 1.8rem;
      z-index: 2;
      font-size: .88rem;
      color: rgba(239, 239, 239, .95);
    }

    .reel-card .p-card-num {
      position: absolute;
      left: 1rem;
      bottom: .7rem;
      z-index: 2;
      font-size: .72rem;
      font-weight: 700;
      color: var(--accent);
      letter-spacing: .25em;
    }

    .reel-card .reel-player {
      position: absolute;
      inset: 0;
      z-index: 1;
      display: block;
    }

    .reel-card.reel-active .p-card-icon {
      display: none;
    }

    .reel-card.reel-active .p-card-lbl,
    .reel-card.reel-active .p-card-num {
      opacity: .85;
    }

    .reel-card.reel-active::before {
      background: rgba(0, 0, 0, .15);
    }

    .reel-card iframe {
